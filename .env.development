APP_ENV=development
DATABASE_URL=postgresql+asyncpg://nc:neuropass@localhost:5432/neurocomment
REDIS_URL=redis://localhost:6379/0
OPS_API_TOKEN=dev-internal-token
JWT_ACCESS_SECRET=dev-access-secret
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=30
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_REFERER=http://localhost:8081
OPENROUTER_DEFAULT_TITLE=NEURO COMMENTING Dev
AI_DEFAULT_MODE=hybrid
AI_ALLOWED_PROVIDER_ORDER=gemini_direct,openrouter
AI_BOSS_MODELS=openrouter:openai/gpt-5.4,openrouter:anthropic/claude-opus-4.6
AI_MANAGER_MODELS=openrouter:anthropic/claude-sonnet-4.6,openrouter:google/gemini-2.5-pro,gemini_direct:gemini-3-pro-preview
AI_WORKER_MODELS=openrouter:google/gemini-2.5-flash,gemini_direct:gemini-3-flash-preview
AI_DAILY_BUDGET_USD=25
AI_MONTHLY_BUDGET_USD=500
AI_BOSS_DAILY_BUDGET_USD=5
AI_HARD_STOP_ENABLED=true
