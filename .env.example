# ========================================
# NEURO COMMENTING — Configuration
# ========================================
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# --- Telegram API ---
# Получить на https://my.telegram.org/auth → API development tools
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=your_api_hash_here

# --- Telegram Admin Bot (опционально, для удалённого управления) ---
ADMIN_BOT_TOKEN=
ADMIN_TELEGRAM_ID=0

# --- Google Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-pro-preview

# --- Google Sheets ---
# Путь к файлу сервисного аккаунта Google
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
CHANNELS_SPREADSHEET_ID=
STATS_SPREADSHEET_ID=

# --- Proxy ---
# Файл со списком прокси (формат: type://user:pass@host:port)
PROXY_LIST_FILE=data/proxies.txt
PROXY_TYPE=socks5

# --- Rate Limits ---
MAX_COMMENTS_PER_ACCOUNT_PER_DAY=35
MIN_DELAY_BETWEEN_COMMENTS_SEC=120
MAX_DELAY_BETWEEN_COMMENTS_SEC=600
COMMENT_COOLDOWN_AFTER_ERROR_SEC=1800

# --- DartVPN Promotion ---
DARTVPN_BOT_LINK=https://t.me/DartVPNBot
DARTVPN_CHANNEL_LINK=
SCENARIO_B_RATIO=0.3

# --- Monitoring / Sync ---
MONITOR_POLL_INTERVAL_SEC=180
POST_MAX_AGE_HOURS=2
SHEETS_SYNC_INTERVAL_SEC=300

# --- Paths ---
SESSIONS_DIR=data/sessions
DB_PATH=data/neuro_commenting.db
LOG_LEVEL=INFO
