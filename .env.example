# ========================================
# NEURO COMMENTING — Configuration
# ========================================
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# --- Telegram API ---
# Получить на https://my.telegram.org/auth → API development tools
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=your_api_hash_here

# --- Telegram Admin Bot ---
ADMIN_BOT_TOKEN=
ADMIN_TELEGRAM_ID=0

# --- Google Gemini API (executor) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-pro-preview
GEMINI_FLASH_MODEL=gemini-3-flash-preview
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_REFERER=
OPENROUTER_DEFAULT_TITLE=NEURO COMMENTING
AI_DEFAULT_MODE=hybrid
AI_ALLOWED_PROVIDER_ORDER=gemini_direct,openrouter
AI_BOSS_MODELS=openrouter:openai/gpt-5.4,openrouter:anthropic/claude-opus-4.6
AI_MANAGER_MODELS=gemini_direct:gemini-3-pro-preview,openrouter:moonshotai/kimi-k2.5,openrouter:anthropic/claude-sonnet-4.6,openrouter:google/gemini-2.5-pro
AI_WORKER_MODELS=gemini_direct:gemini-3-flash-preview,openrouter:google/gemini-2.5-flash,openrouter:moonshotai/kimi-k2.5
AI_DAILY_BUDGET_USD=25
AI_MONTHLY_BUDGET_USD=500
AI_BOSS_DAILY_BUDGET_USD=5
AI_HARD_STOP_ENABLED=true

# --- Product (generic) ---
PRODUCT_NAME=DartVPN
PRODUCT_BOT_USERNAME=DartVPNBot
PRODUCT_BOT_LINK=https://t.me/DartVPNBot?start=fly
PRODUCT_CHANNEL_LINK=
PRODUCT_AVATAR_PATH=data/avatars/dartvpn_banner.jpg
PRODUCT_SHORT_DESC=VPN с оплатой за гигабайты
PRODUCT_FEATURES=оплата по ГБ, карта Мир, работает в Telegram
PRODUCT_CATEGORY=VPN
PRODUCT_CHANNEL_PREFIX=dartvpn
SCENARIO_B_RATIO=0.3

# --- Google Sheets (optional) ---
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
CHANNELS_SPREADSHEET_ID=
STATS_SPREADSHEET_ID=

# --- Proxy ---
PROXY_LIST_FILE=data/proxies.txt
PROXY_TYPE=socks5
PROXY_ROTATING=false
PROXY_STICKY_FORMAT={user}-session-{session_id}

# --- Rate Limits ---
MAX_COMMENTS_PER_ACCOUNT_PER_DAY=35
MIN_DELAY_BETWEEN_COMMENTS_SEC=120
MAX_DELAY_BETWEEN_COMMENTS_SEC=600
COMMENT_COOLDOWN_AFTER_ERROR_SEC=1800
MIN_EXISTING_COMMENTS_BEFORE_COMMENT=2
MIN_COMMENTS_RECHECK_MAX_ATTEMPTS=12
WARMUP_LIGHT_LIMIT=3
WARMUP_MODERATE_LIMIT=8

# --- Session health / keep-alive ---
SESSION_HEALTH_CHECK_HOURS=4
KEEP_ALIVE_INTERVAL_HOURS=6
ACCOUNT_SLEEP_START_HOUR=23
ACCOUNT_SLEEP_END_HOUR=7
SESSION_BACKUP_KEY=

# --- Monitoring / sync ---
MONITOR_POLL_INTERVAL_SEC=180
POST_MAX_AGE_HOURS=2
SHEETS_SYNC_INTERVAL_SEC=300

# --- Infrastructure ---
# Leave DATABASE_URL empty for local SQLite mode.
# Set DATABASE_URL for production PostgreSQL mode.
DATABASE_URL=
REDIS_URL=redis://localhost:6379/0
OPS_API_URL=
OPS_API_HOST=0.0.0.0
OPS_API_PORT=8081
OPS_API_TOKEN=
DIGEST_BOT_TOKEN=
DIGEST_CHAT_ID=
DIGEST_MAX_ITEMS=10
DIGEST_DAILY_HOUR_UTC=9
DIGEST_DAILY_MINUTE_UTC=0
DIGEST_SCHEDULE_ENABLED=true
WORKER_ID=main
PINNED_PHONE=
MAX_ACCOUNTS_PER_WORKER=50
MAX_CONNECTED_CLIENTS_PER_WORKER=50
WORKER_CONNECT_BATCH_SIZE=5
WORKER_DEQUEUE_TIMEOUT_SEC=5
STRICT_PROXY_PER_ACCOUNT=true
PINNED_PHONE_REQUIRED=true
PACKAGING_DELAY_SCALE=1.0
PACKAGING_DELAY_MIN_SEC=30
PACKAGING_DELAY_MAX_SEC=120
PACKAGING_ALLOW_BIO_FALLBACK=true
ENABLE_LEGACY_COMMENTING=false
ENABLE_EMOJI_SWAP=false
NEW_ACCOUNT_LAUNCH_MODE=faster_1d
STRICT_PARSER_ONLY=true
FROZEN_PROBE_ON_CONNECT=true
FROZEN_PROBE_BEFORE_PACKAGING=true
FROZEN_PROBE_BEFORE_PARSER=true
WORKER_A_PINNED_PHONE=
WORKER_B_PINNED_PHONE=
WORKER_A_PROXY_LIST_FILE=data/proxies.txt
WORKER_B_PROXY_LIST_FILE=data/proxies.txt
# Distributed v2: production mode on VPS.
# bot enqueues tasks to Redis, workers consume and execute.
# Keep false only for local dry-run / legacy debugging.
DISTRIBUTED_QUEUE_MODE=false
COMPLIANCE_MODE=strict
POLICY_RULES_PATH=policy/rules.yaml
PARSER_ONLY_PHONE=
PARSER_MIN_SUBSCRIBERS=500
PARSER_REQUIRE_COMMENTS=true
PARSER_REQUIRE_RUSSIAN=true
PARSER_STAGE1_LIMIT=30
MANUAL_GATE_REQUIRED=true
ENABLE_CLIENT_WIZARD=true
ENABLE_ADMIN_LEGACY_TOOLS=true
STRICT_SLO_WINDOW_DAYS=30
API_ID_4_STRICT_MODE=true
AUTO_SPAMBOT_APPEAL_ENABLED=false
AUTO_SPAMBOT_APPEAL_INTERVAL_SEC=900
AUTO_SPAMBOT_CHECK_COOLDOWN_HOURS=6
AUTO_SPAMBOT_APPEAL_COOLDOWN_HOURS=24
AUTO_SPAMBOT_APPEAL_MAX_STEPS=20
AUTO_SPAMBOT_APPEAL_BATCH_SIZE=5
AUTO_SPAMBOT_APPEAL_EMAIL=
AUTO_SPAMBOT_APPEAL_REG_YEAR=2024

# --- Paths ---
SESSIONS_DIR=data/sessions
PROFILE_AVATARS_DIR=data/avatars/profiles
DB_PATH=data/neuro_commenting.db
LOG_LEVEL=INFO

# --- Legacy compatibility (one release, avoid for new setups) ---
# DARTVPN_BOT_LINK=
# DARTVPN_CHANNEL_LINK=
# DARTVPN_AVATAR_PATH=
